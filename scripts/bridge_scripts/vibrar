#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 📳 vibrar — Vibrar el dispositivo
# Duración en milisegundos (por defecto 500ms)
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/vibrar [ms]
# ═══════════════════════════════════════════════════════════

DURACION="${1:-500}"

termux-vibrate -d "$DURACION" 2>/dev/null

echo "📳 Vibración: ${DURACION}ms"
