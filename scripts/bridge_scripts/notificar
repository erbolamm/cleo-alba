#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 🔔 notificar — Mostrar notificación en Android
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/notificar "título" "contenido"
# ═══════════════════════════════════════════════════════════

TITULO="${1:-ApliBot}"
CONTENIDO="${2:-Notificación sin contenido}"

termux-notification --title "$TITULO" --content "$CONTENIDO" 2>/dev/null

if [ $? -eq 0 ]; then
    echo "✅ Notificación enviada: $TITULO"
else
    echo "❌ Error enviando notificación"
    exit 1
fi
