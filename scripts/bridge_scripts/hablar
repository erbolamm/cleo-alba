#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 🔊 hablar — TTS por altavoz principal
# Usa espeak-ng → WAV → termux-media-player (STREAM_MUSIC)
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/hablar "texto"
# ═══════════════════════════════════════════════════════════

TEXT="$*"
if [ -z "$TEXT" ]; then
    echo "Uso: hablar <texto>"
    exit 1
fi

WAV="/sdcard/tts_output.wav"

# Generar WAV con espeak-ng (voz española)
espeak-ng -v es "$TEXT" -w "$WAV" 2>/dev/null || espeak -v es "$TEXT" --stdout > "$WAV" 2>/dev/null

if [ ! -s "$WAV" ]; then
    echo "❌ Error generando audio"
    exit 1
fi

# Reproducir por STREAM_MUSIC (altavoz principal, no auricular)
termux-media-player play "$WAV" 2>/dev/null &
PLAY_PID=$!

# Esperar a que termine (máx 30s)
WAITED=0
while kill -0 $PLAY_PID 2>/dev/null && [ $WAITED -lt 30 ]; do
    sleep 1
    WAITED=$((WAITED + 1))
done

# Limpiar
rm -f "$WAV" 2>/dev/null
