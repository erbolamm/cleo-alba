#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 📸 captura — Captura de pantalla del dispositivo
# Guarda en /sdcard/ con nombre personalizable
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/captura [nombre.png]
# ═══════════════════════════════════════════════════════════

NOMBRE="${1:-captura_$(date +%Y%m%d_%H%M%S).png}"

# Asegurar extensión .png
[[ "$NOMBRE" != *.png ]] && NOMBRE="${NOMBRE}.png"

RUTA="/sdcard/$NOMBRE"

screencap -p "$RUTA" 2>/dev/null

if [ -f "$RUTA" ] && [ -s "$RUTA" ]; then
    echo "✅ Captura guardada: $RUTA"
else
    echo "❌ Error capturando pantalla"
    exit 1
fi
