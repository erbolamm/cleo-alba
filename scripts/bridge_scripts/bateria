#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 🔋 bateria — Consultar estado de la batería
# Devuelve JSON con nivel, estado, temperatura, etc.
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/bateria
# ═══════════════════════════════════════════════════════════

BATT=$(termux-battery-status 2>/dev/null)

if [ -n "$BATT" ]; then
    NIVEL=$(echo "$BATT" | grep -o '"percentage":[0-9]*' | cut -d: -f2)
    ESTADO=$(echo "$BATT" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    TEMP=$(echo "$BATT" | grep -o '"temperature":[0-9.]*' | cut -d: -f2)
    
    echo "🔋 Batería: ${NIVEL}% | Estado: ${ESTADO} | Temp: ${TEMP}°C"
    echo "$BATT"
else
    echo "❌ Error consultando batería"
    exit 1
fi
