#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 🔦 linterna — Encender/apagar la linterna (flash LED)
# Uso: linterna on | linterna off (por defecto: toggle)
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/linterna [on|off]
# ═══════════════════════════════════════════════════════════

ACCION="${1:-on}"

case "$ACCION" in
    on|encender|1)
        termux-torch on 2>/dev/null
        echo "🔦 Linterna encendida"
        ;;
    off|apagar|0)
        termux-torch off 2>/dev/null
        echo "🔦 Linterna apagada"
        ;;
    *)
        echo "Uso: linterna [on|off]"
        exit 1
        ;;
esac
