#!/data/data/com.termux/files/usr/bin/bash
# ═══════════════════════════════════════════════════════════
# 🌐 abrir_web — Abrir URL en el navegador del dispositivo
# Si no se pasa URL, abre la web pública de ApliBot
# Callable desde PRoot: /data/data/com.termux/files/usr/bin/abrir_web [URL]
# ═══════════════════════════════════════════════════════════

URL="${1:-https://erbolamm.github.io/aplibot-web/}"

am start -a android.intent.action.VIEW -d "$URL" >/dev/null 2>&1

if [ $? -eq 0 ]; then
    echo "✅ Abriendo: $URL"
else
    echo "❌ Error abriendo URL"
    exit 1
fi
